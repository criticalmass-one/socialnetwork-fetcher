{{ form_start(form) }}
    <div class="data-card">
        <div class="data-card-body">
            {{ form_row(form.network) }}
            {% if form.id is defined %}
                {{ form_row(form.id) }}
            {% endif %}
            {{ form_row(form.identifier) }}
            {{ form_row(form.title) }}
            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.autoFetch) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.fetchSource) }}
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.savePhotos) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.saveVideos) }}
                </div>
            </div>
            {{ form_row(form.additionalData) }}
        </div>
        <div class="data-card-body border-top">
            <button type="submit" class="btn-primary-custom">
                <i class="fas fa-save me-1"></i>Speichern
            </button>
            <a href="{{ cancel_url }}" class="btn btn-secondary">Abbrechen</a>
        </div>
    </div>
{{ form_end(form) }}
