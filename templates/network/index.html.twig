{% extends 'base.html.twig' %}

{% block title %}Networks - Social Network Fetcher{% endblock %}

{% block page_title %}Networks{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_network_new') }}" class="btn-primary-custom">
        <i class="fas fa-plus me-1"></i>Neues Netzwerk
    </a>
{% endblock %}

{% block body %}
    {% if networks is empty %}
        <div class="alert alert-info">
            Keine Netzwerke gefunden.
            <a href="{{ path('app_network_new') }}">Erstes Netzwerk anlegen?</a>
        </div>
    {% else %}
        <div class="data-card">
            <div class="data-card-body">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Identifier</th>
                            <th>Icon</th>
                            <th>Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for network in networks %}
                            <tr>
                                <td>{{ network.id }}</td>
                                <td>
                                    <span class="net-badge" style="background: rgba({{ network.backgroundColor|replace({'#': ''}) }}, 0.1); background-color: {{ network.backgroundColor }}; color: {{ network.textColor }};">
                                        <i class="{{ network.icon }} me-1"></i>{{ network.name }}
                                    </span>
                                </td>
                                <td>
                                    <a href="{{ path('app_network_show', {id: network.id}) }}">
                                        {{ network.identifier }}
                                    </a>
                                </td>
                                <td><code>{{ network.icon }}</code></td>
                                <td>
                                    <a href="{{ path('app_network_show', {id: network.id}) }}" class="action-btn" title="Anzeigen">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_network_edit', {id: network.id}) }}" class="action-btn" title="Bearbeiten">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_network_delete', {id: network.id}) }}"
                                          class="d-inline"
                                          data-controller="confirm"
                                          data-confirm-message-value="Netzwerk &quot;{{ network.name }}&quot; wirklich löschen?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-network-' ~ network.id) }}">
                                        <button type="submit" class="action-btn" title="Löschen">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}
