{% extends 'base.html.twig' %}

{% block title %}Client {{ client.name }} - Social Network Fetcher{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_client_index') }}">Clients</a></li>
            <li class="breadcrumb-item active">{{ client.name }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ client.name }}</h1>
        <div>
            {% if client.enabled %}
                <span class="badge bg-success fs-6">Aktiv</span>
            {% else %}
                <span class="badge bg-danger fs-6">Deaktiviert</span>
            {% endif %}
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">Details</div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th style="width: 200px;">ID</th>
                            <td>{{ client.id }}</td>
                        </tr>
                        <tr>
                            <th>Name</th>
                            <td>{{ client.name }}</td>
                        </tr>
                        <tr>
                            <th>Token</th>
                            <td><code>{{ client.token }}</code></td>
                        </tr>
                        <tr>
                            <th>Erstellt am</th>
                            <td>{{ client.createdAt|date('d.m.Y H:i:s') }}</td>
                        </tr>
                    </table>
                </div>
            </div>

            {% if client.profiles|length > 0 %}
                <div class="card mb-4">
                    <div class="card-header">Verknüpfte Profile ({{ client.profiles|length }})</div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Netzwerk</th>
                                    <th>Identifier</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for profile in client.profiles %}
                                    <tr>
                                        <td>{{ profile.id }}</td>
                                        <td>
                                            {% if profile.network %}
                                                <span class="badge badge-network" style="background-color: {{ profile.network.backgroundColor }}; color: {{ profile.network.textColor }};">
                                                    <i class="{{ profile.network.icon }} me-1"></i>{{ profile.network.name }}
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('app_profile_show', {id: profile.id}) }}">
                                                {{ profile.identifier }}
                                            </a>
                                        </td>
                                        <td>
                                            {% if profile.deleted %}
                                                <span class="badge bg-danger">Gelöscht</span>
                                            {% else %}
                                                <span class="badge bg-success">Aktiv</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">Aktionen</div>
                <div class="card-body d-grid gap-2">
                    <form method="post" action="{{ path('app_client_regenerate_token', {id: client.id}) }}"
                          data-controller="confirm"
                          data-confirm-message-value="Token wirklich neu generieren? Das alte Token wird sofort ungültig.">
                        <input type="hidden" name="_token" value="{{ csrf_token('regenerate-token-' ~ client.id) }}">
                        <button type="submit" class="btn btn-outline-warning w-100">
                            <i class="fas fa-key me-1"></i>Token neu generieren
                        </button>
                    </form>
                    <form method="post" action="{{ path('app_client_toggle_enabled', {id: client.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-client-' ~ client.id) }}">
                        {% if client.enabled %}
                            <button type="submit" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-ban me-1"></i>Deaktivieren
                            </button>
                        {% else %}
                            <button type="submit" class="btn btn-outline-success w-100">
                                <i class="fas fa-check me-1"></i>Aktivieren
                            </button>
                        {% endif %}
                    </form>
                    <form method="post" action="{{ path('app_client_delete', {id: client.id}) }}"
                          data-controller="confirm"
                          data-confirm-message-value="Client &quot;{{ client.name }}&quot; wirklich löschen?">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-client-' ~ client.id) }}">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="fas fa-trash me-1"></i>Löschen
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
