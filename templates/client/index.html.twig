{% extends 'base.html.twig' %}

{% block title %}Clients - Social Network Fetcher{% endblock %}

{% block page_title %}Clients{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_client_new') }}" class="btn-primary-custom">
        <i class="fas fa-plus me-1"></i>Neuer Client
    </a>
{% endblock %}

{% block body %}
    {% if clients is empty %}
        <div class="alert alert-info">
            Keine Clients gefunden.
            <a href="{{ path('app_client_new') }}">Ersten Client anlegen?</a>
        </div>
    {% else %}
        <div class="data-card">
            <div class="data-card-body">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Aktiv</th>
                            <th>Profile</th>
                            <th>Erstellt</th>
                            <th>Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for client in clients %}
                            <tr>
                                <td>{{ client.id }}</td>
                                <td>
                                    <a href="{{ path('app_client_show', {id: client.id}) }}">
                                        {{ client.name }}
                                    </a>
                                </td>
                                <td>
                                    {% if client.enabled %}
                                        <span class="badge bg-success">Aktiv</span>
                                    {% else %}
                                        <span class="badge bg-danger">Deaktiviert</span>
                                    {% endif %}
                                </td>
                                <td>{{ client.profiles|length }}</td>
                                <td>{{ client.createdAt|date('d.m.Y H:i') }}</td>
                                <td>
                                    <a href="{{ path('app_client_show', {id: client.id}) }}" class="action-btn" title="Anzeigen">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}
