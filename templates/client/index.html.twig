{% extends 'base.html.twig' %}

{% block title %}Clients - Social Network Fetcher{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Clients</h1>
        <a href="{{ path('app_client_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Neuer Client
        </a>
    </div>

    {% if clients is empty %}
        <div class="alert alert-info">
            Keine Clients gefunden.
            <a href="{{ path('app_client_new') }}">Ersten Client anlegen?</a>
        </div>
    {% else %}
        <table class="table table-hover table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Aktiv</th>
                    <th>Profile</th>
                    <th>Erstellt</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for client in clients %}
                    <tr>
                        <td>{{ client.id }}</td>
                        <td>
                            <a href="{{ path('app_client_show', {id: client.id}) }}">
                                {{ client.name }}
                            </a>
                        </td>
                        <td>
                            {% if client.enabled %}
                                <span class="badge bg-success">Aktiv</span>
                            {% else %}
                                <span class="badge bg-danger">Deaktiviert</span>
                            {% endif %}
                        </td>
                        <td>{{ client.profiles|length }}</td>
                        <td>{{ client.createdAt|date('d.m.Y H:i') }}</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_client_show', {id: client.id}) }}" class="btn btn-outline-primary" title="Anzeigen">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
