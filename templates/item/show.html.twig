{% extends 'base.html.twig' %}

{% block title %}Item #{{ item.id }} - Social Network Fetcher{% endblock %}

{% block page_title %}Item #{{ item.id }}{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_item_edit', {id: item.id}) }}" class="btn-primary-custom">
        <i class="fas fa-edit me-1"></i>Bearbeiten
    </a>
{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_item_index', item.profile ? {profile: item.profile.id} : {}) }}">Items</a></li>
            <li class="breadcrumb-item active">#{{ item.id }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="data-card mb-4">
                <div class="data-card-header">Inhalt</div>
                <div class="data-card-body">
                    {% if item.title %}
                        <h5>{{ item.title }}</h5>
                        <hr>
                    {% endif %}
                    <p class="mb-0" style="white-space: pre-wrap;">{{ item.text }}</p>
                </div>
            </div>

            <div class="data-card mb-4" id="media-card">
                <div class="data-card-header">Medien</div>
                <div class="data-card-body">
                    <div class="media-content">
                        {% if item.photoPaths|length > 0 %}
                            <div class="row g-2 mb-3">
                                {% for photoPath in item.photoPaths %}
                                    <div class="col-{{ item.photoPaths|length == 1 ? '12' : '6' }}">
                                        <img src="/media/{{ photoPath }}" class="img-fluid rounded" alt="Foto {{ loop.index }}">
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {% if item.videoPath %}
                            <div class="mb-3">
                                <video src="/media/{{ item.videoPath }}" controls class="w-100 rounded"></video>
                            </div>
                        {% endif %}
                        {% if item.photoPaths|length == 0 and not item.videoPath %}
                            <p class="text-muted mb-0">Keine Medien heruntergeladen.</p>
                        {% endif %}
                    </div>
                    {% if item.mediaStatus == 'failed' and item.mediaError %}
                        <div class="alert alert-danger mt-3 mb-0">
                            <i class="fas fa-exclamation-triangle me-1"></i>{{ item.mediaError }}
                        </div>
                    {% endif %}
                    {% if item.mediaStatus %}
                        <div class="mt-2">
                            <small class="text-muted">Status: </small>
                            {% if item.mediaStatus == 'completed' %}
                                <span class="badge bg-success">{{ item.mediaStatus }}</span>
                            {% elseif item.mediaStatus == 'failed' %}
                                <span class="badge bg-danger">{{ item.mediaStatus }}</span>
                            {% elseif item.mediaStatus == 'downloading' %}
                                <span class="badge bg-info">{{ item.mediaStatus }}</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ item.mediaStatus }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="mt-3">
                        <button type="button"
                                class="btn btn-outline-primary w-100"
                                data-controller="media-download"
                                data-media-download-url-value="{{ path('app_item_download_media', {id: item.id}) }}"
                                data-media-download-token-value="{{ csrf_token('download-media-' ~ item.id) }}"
                                data-action="media-download#download">
                            <i class="fas fa-download me-1"></i>Medien herunterladen
                        </button>
                    </div>
                </div>
            </div>

            {% if item.raw %}
                <div class="data-card mb-4">
                    <div class="data-card-header">Rohdaten</div>
                    <div class="data-card-body">
                        <pre class="raw-data mb-0">{{ item.raw }}</pre>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-md-4">
            <div class="data-card mb-4">
                <div class="data-card-header">Details</div>
                <div class="data-card-body">
                    <table class="detail-table">
                        <tr>
                            <th>Profil</th>
                            <td>
                                {% if item.profile %}
                                    <a href="{{ path('app_profile_show', {id: item.profile.id}) }}">
                                        {{ item.profile.identifier }}
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Netzwerk</th>
                            <td>
                                {% if item.profile and item.profile.network %}
                                    <span class="net-badge" style="background-color: {{ item.profile.network.backgroundColor }}; color: {{ item.profile.network.textColor }};">
                                        <i class="{{ item.profile.network.icon }} me-1"></i>{{ item.profile.network.name }}
                                    </span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Unique-ID</th>
                            <td><code>{{ item.uniqueIdentifier }}</code></td>
                        </tr>
                        <tr>
                            <th>Datum</th>
                            <td>{{ item.dateTime|date('d.m.Y H:i:s') }}</td>
                        </tr>
                        <tr>
                            <th>Erstellt am</th>
                            <td>{{ item.createdAt|date('d.m.Y H:i:s') }}</td>
                        </tr>
                        {% if item.permalink %}
                            <tr>
                                <th>Permalink</th>
                                <td>
                                    <a href="{{ item.permalink }}" target="_blank" rel="noopener">
                                        <i class="fas fa-external-link-alt me-1"></i>Öffnen
                                    </a>
                                </td>
                            </tr>
                        {% endif %}
                    </table>
                </div>
            </div>

            <div class="data-card mb-4" data-controller="toggle"
                 data-toggle-id-value="{{ item.id }}"
                 data-toggle-token-value="{{ csrf_token('toggle-item-' ~ item.id) }}">
                <div class="data-card-header">Status</div>
                <div class="data-card-body d-grid gap-2">
                    <button class="btn {{ item.hidden ? 'btn-warning' : 'btn-outline-warning' }}"
                            data-action="toggle#toggleHidden"
                            data-toggle-target="hiddenBtn">
                        <i class="fas fa-eye-slash me-1"></i>
                        <span data-toggle-target="hiddenLabel">{{ item.hidden ? 'Versteckt' : 'Nicht versteckt' }}</span>
                    </button>
                    <button class="btn {{ item.deleted ? 'btn-danger' : 'btn-outline-danger' }}"
                            data-action="toggle#toggleDeleted"
                            data-toggle-target="deletedBtn">
                        <i class="fas fa-trash me-1"></i>
                        <span data-toggle-target="deletedLabel">{{ item.deleted ? 'Gelöscht' : 'Nicht gelöscht' }}</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="mediaDownloadModal" tabindex="-1" aria-labelledby="mediaDownloadModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="mediaDownloadModalLabel">Medien herunterladen</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body"></div>
                <div class="modal-footer d-none">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
